PORT=3000
IDENTITY_GRPC_URL=localhost:50052
ECOMMERCE_GRPC_URL=localhost:50051
BIOMETRIC_GRPC_URL=localhost:50053

# =========================================================
# AUTH / JWT
# =========================================================
JWT_ACCESS_TOKEN_SECRET=your_access_token_secret_key_here_min_32_chars
JWT_REFRESH_TOKEN_SECRET=your_refresh_token_secret_key_here_min_32_chars
JWT_ACCESS_TOKEN_EXPIRATION=86400
JWT_REFRESH_TOKEN_EXPIRATION=2592000000
FRONTEND_URL=http://localhost:3000
DEFAULT_USER_ROLE=CUSTOMER

# =========================================================
# RABBITMQ
# =========================================================
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=myapp

# =========================================================
# REDIS
# =========================================================
REDIS_URL=redis://localhost:6379

# =========================================================
# POSTGRESQL (Prisma)
# =========================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=bioring
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/bioring?schema=public

# =========================================================
# MONGODB
# =========================================================
MONGODB_URI=mongodb://localhost:27017/mydb

# =========================================================
# GOOGLE OAUTH
# =========================================================
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
