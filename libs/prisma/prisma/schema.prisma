generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This model has constraints using non-default deferring rules and requires additional setup for migrations. Visit https://pris.ly/d/constraint-deferring for more info.
model ai_messages {
  id            String      @id @db.Uuid
  ai_session_id String      @db.Uuid
  sender        String?     @db.VarChar(50)
  message       String?
  metadata      Json?
  created_at    DateTime?   @db.Timestamptz(6)
  ai_sessions   ai_sessions @relation(fields: [ai_session_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model has constraints using non-default deferring rules and requires additional setup for migrations. Visit https://pris.ly/d/constraint-deferring for more info.
model ai_sessions {
  id                   String          @id @db.Uuid
  user_id              String?         @db.Uuid
  guest_session_id     String?         @db.VarChar(255)
  topic                String?         @db.VarChar(255)
  summary              String?
  final_recommendation Json?
  created_at           DateTime?       @db.Timestamptz(6)
  updated_at           DateTime?       @db.Timestamptz(6)
  ai_messages          ai_messages[]
  users                users?          @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
