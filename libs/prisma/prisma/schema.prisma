}

/// This model has constraints using non-default deferring rules and requires additional setup for migrations. Visit https://pris.ly/d/constraint-deferring for more info.
model biometric_capture_items {
  id                         String                     @id @db.Uuid
  capture_session_id         String                     @db.Uuid
  capture_type               String?                    @db.VarChar(100)
  raw_file_url               String?                    @db.VarChar(500)
  processed_file_url         String?                    @db.VarChar(500)
  svg_url                    String?                    @db.VarChar(500)
  metadata                   Json?
  quality_score              Decimal?                   @db.Decimal(5, 2)
  upload_source              String?                    @db.VarChar(50)
